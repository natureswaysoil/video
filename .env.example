# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_SYSTEM_PROMPT=
OPENAI_USER_TEMPLATE=

# HeyGen Configuration
HEYGEN_API_KEY=your-heygen-api-key
HEYGEN_API_ENDPOINT=https://api.heygen.com
GCP_SECRET_HEYGEN_API_KEY=

# Google Sheets Configuration
GS_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GS_SERVICE_ACCOUNT_KEY=

# Twitter/X Configuration
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# YouTube Configuration
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Instagram Configuration
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_API_VERSION=v19.0
INSTAGRAM_API_HOST=graph.facebook.com
IG_MEDIA_TYPE=REELS
IG_UPLOAD_TYPE=simple

# Pinterest Configuration
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# Cloudinary (required only when TEST_VIDEO_CAMPAIGN_MODE=true and TEST_VIDEO_PUBLIC_BASE_URL is not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CSV Column Mappings
CSV_COL_JOB_ID=
CSV_COL_TITLE=
CSV_COL_DETAILS=
CSV_COL_ID=
CSV_COL_NAME=
CSV_COL_POSTED=
CSV_COL_READY=
CSV_COL_POSTED_AT=
CSV_STATUS_TRUE_VALUES=

# Processing Options
ALWAYS_GENERATE_NEW_VIDEO=false
DRY_RUN=false
DRY_RUN_LOG_ONLY=false

# Test Video Campaign Mode (uses /home/ubuntu/test_videos by default)
TEST_VIDEO_CAMPAIGN_MODE=false
TEST_VIDEOS_DIR=/home/ubuntu/test_videos
USE_SECRET_MANAGER=false
# Optional: set to a CDN/base URL where test videos are already hosted.
# If omitted, local videos are uploaded to Cloudinary once and cached.
TEST_VIDEO_PUBLIC_BASE_URL=

# Optional scheduler overrides (node-cron syntax)
SCHEDULER_PIPELINE_COMMAND=npm run run:once
SCHEDULER_GENERATE_ROWS_COMMAND=npm run generate:rows
SCHEDULER_ROW_GENERATION_CRON=0 7 * * *
SCHEDULER_POST_TIMES=15 8 * * *,30 11 * * *,0 13 * * *,15 18 * * *,30 19 * * *

# Platform Selection
# Comma-separated list of platforms to enable (instagram,twitter,pinterest,youtube)
# Leave empty to enable all platforms with valid credentials
# Examples:
#   ENABLE_PLATFORMS=               # All platforms with credentials
#   ENABLE_PLATFORMS=instagram      # Instagram only
#   ENABLE_PLATFORMS=instagram,twitter  # Instagram and Twitter only
ENABLE_PLATFORMS=

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret

# Supabase (for processing locks and idempotency)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Rate Limiting (requests per minute)
RATE_LIMIT_OPENAI=10
RATE_LIMIT_HEYGEN=5
RATE_LIMIT_TWITTER=50
RATE_LIMIT_YOUTUBE=10
RATE_LIMIT_INSTAGRAM=25
RATE_LIMIT_PINTEREST=5

# Timeouts (in milliseconds)
TIMEOUT_OPENAI=30000
TIMEOUT_HEYGEN=1200000
TIMEOUT_SOCIAL_POST=60000

# Memory Management
MAX_VIDEO_SIZE_MB=500
ENABLE_STREAMING_UPLOADS=true

# Logging
LOG_LEVEL=info
ENABLE_METRICS=true
AUDIT_LOG_FILE=/tmp/audit.log

# Environment
NODE_ENV=development
