# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_SYSTEM_PROMPT=
OPENAI_USER_TEMPLATE=

# HeyGen Configuration (Paid option: $29-89/month)
HEYGEN_API_KEY=your-heygen-api-key
HEYGEN_API_ENDPOINT=https://api.heygen.com
GCP_SECRET_HEYGEN_API_KEY=

# Free Video Generation Alternative (MoviePy + Pexels + ElevenLabs/gTTS)
# Set to 'true' to use free video generation instead of HeyGen
USE_FREE_VIDEO_GENERATOR=false
PEXELS_API_KEY=your_free_pexels_api_key
GCS_BUCKET_NAME=natureswaysoil-videos

# ElevenLabs Voice (FREE 10k chars/month - sounds WAY better than gTTS)
# Get your free API key from https://elevenlabs.io/
# If not set, will fallback to gTTS (robotic voice)
ELEVENLABS_API_KEY=your_free_api_key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL  # Optional: Sarah (default female voice)

# Product image column mapping (optional - auto-detects)
# Checks these columns in order: PRODUCT_IMAGE_COLUMN, Image_URL, Product_Image, ASIN_Image, Image
PRODUCT_IMAGE_COLUMN=Image_URL

# Google Sheets Configuration
GS_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GS_SERVICE_ACCOUNT_KEY=

# Twitter/X Configuration
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# YouTube Configuration
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Instagram Configuration
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_API_VERSION=v19.0
INSTAGRAM_API_HOST=graph.facebook.com
IG_MEDIA_TYPE=REELS
IG_UPLOAD_TYPE=simple

# Pinterest Configuration
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# CSV Column Mappings
CSV_COL_JOB_ID=
CSV_COL_TITLE=
CSV_COL_DETAILS=
CSV_COL_ID=
CSV_COL_NAME=
CSV_COL_POSTED=
CSV_COL_READY=
CSV_COL_POSTED_AT=
CSV_STATUS_TRUE_VALUES=

# Processing Options
ALWAYS_GENERATE_NEW_VIDEO=false
DRY_RUN=false

# Platform Selection
# Comma-separated list of platforms to enable (instagram,twitter,pinterest,youtube)
# Leave empty to enable all platforms with valid credentials
# Examples:
#   ENABLE_PLATFORMS=               # All platforms with credentials
#   ENABLE_PLATFORMS=instagram      # Instagram only
#   ENABLE_PLATFORMS=instagram,twitter  # Instagram and Twitter only
ENABLE_PLATFORMS=

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret

# Supabase (for processing locks and idempotency)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Rate Limiting (requests per minute)
RATE_LIMIT_OPENAI=10
RATE_LIMIT_HEYGEN=5
RATE_LIMIT_TWITTER=50
RATE_LIMIT_YOUTUBE=10
RATE_LIMIT_INSTAGRAM=25
RATE_LIMIT_PINTEREST=5

# Timeouts (in milliseconds)
TIMEOUT_OPENAI=30000
TIMEOUT_HEYGEN=1200000
TIMEOUT_SOCIAL_POST=60000

# Memory Management
MAX_VIDEO_SIZE_MB=500
ENABLE_STREAMING_UPLOADS=true

# Logging
LOG_LEVEL=info
ENABLE_METRICS=true
AUDIT_LOG_FILE=/tmp/audit.log

# Environment
NODE_ENV=development
