# Product Video Automation Engine environment template
# Copy to .env for local development. Never commit real secrets or client data.

# Environment
NODE_ENV=development
DRY_RUN=true
DRY_RUN_LOG_ONLY=true
LOG_LEVEL=info
ENABLE_METRICS=true
AUDIT_LOG_FILE=/tmp/product-video-engine-audit.log

# License / client controls
CLIENT_ID=
LICENSE_KEY=
DEFAULT_BRAND_NAME=
DEFAULT_BRAND_WEBSITE=
DEFAULT_CTA_URL=

# Product feed
# Use CSV_URL for a public/exported CSV or GOOGLE_SHEET_CSV_URL for a Google Sheet CSV export.
CSV_URL=
GOOGLE_SHEET_CSV_URL=

# CSV Column Mappings
CSV_COL_JOB_ID=
CSV_COL_TITLE=
CSV_COL_DETAILS=
CSV_COL_ID=
CSV_COL_NAME=
CSV_COL_POSTED=
CSV_COL_READY=
CSV_COL_POSTED_AT=
CSV_STATUS_TRUE_VALUES=

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SYSTEM_PROMPT=
OPENAI_USER_TEMPLATE=
RATE_LIMIT_OPENAI=10
TIMEOUT_OPENAI=30000

# HeyGen Configuration
HEYGEN_API_KEY=
HEYGEN_API_ENDPOINT=https://api.heygen.com
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
GCP_SECRET_HEYGEN_API_KEY=
RATE_LIMIT_HEYGEN=5
TIMEOUT_HEYGEN=1200000

# Google Sheets / Google Cloud / Secret Manager
USE_SECRET_MANAGER=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GS_SERVICE_ACCOUNT_EMAIL=
GS_SERVICE_ACCOUNT_KEY=

# Media / B-roll providers
PEXELS_API_KEY=
GCP_SECRET_PEXELS_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Supabase, if used for job tracking, locks, and idempotency
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Social / publishing integrations
# Comma-separated list of platforms to enable: instagram,twitter,pinterest,youtube
ENABLE_PLATFORMS=

# Twitter/X Configuration
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
RATE_LIMIT_TWITTER=50

# YouTube Configuration
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
RATE_LIMIT_YOUTUBE=10

# Instagram Configuration
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_API_VERSION=v19.0
INSTAGRAM_API_HOST=graph.facebook.com
IG_MEDIA_TYPE=REELS
IG_UPLOAD_TYPE=simple
RATE_LIMIT_INSTAGRAM=25

# Pinterest Configuration
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
RATE_LIMIT_PINTEREST=5

# Processing Options
ALWAYS_GENERATE_NEW_VIDEO=false
TIMEOUT_SOCIAL_POST=60000
MAX_VIDEO_SIZE_MB=500
ENABLE_STREAMING_UPLOADS=true

# Test Video Campaign Mode
TEST_VIDEO_CAMPAIGN_MODE=false
TEST_VIDEOS_DIR=/tmp/test_videos
TEST_VIDEO_PUBLIC_BASE_URL=

# Scheduler overrides, node-cron syntax
SCHEDULER_PIPELINE_COMMAND=npm run run:once
SCHEDULER_GENERATE_ROWS_COMMAND=npm run generate:rows
SCHEDULER_ROW_GENERATION_CRON=0 7 * * *
SCHEDULER_POST_TIMES=15 8 * * *,30 11 * * *,0 13 * * *,15 18 * * *,30 19 * * *

# Webhook Configuration
WEBHOOK_SECRET=

# Seed rotation demo mode
USE_SEED_ROTATION=false
SEED_PRODUCT_LIMIT=5
VARIATIONS_PER_PRODUCT=5
TOP_PRODUCTS_FILE=config/top-products.json
ROTATION_STATE_FILE=data/rotation-state.json
ROTATION_STATE_GCS_URI=
PUBLIC_SITE_URL=

# Local b-roll compositor, requires ffmpeg + ffprobe on PATH
ENABLE_LOCAL_BROLL_COMPOSE=false
BROLL_PIP_POSITION=tr
BROLL_PIP_SCALE=0.36
